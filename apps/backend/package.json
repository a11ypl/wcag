{
  "name": "@wlacz-wizje/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "db:migrate": "ts-node --project tsconfig.json scripts/migrate.ts",
    "db:seed": "ts-node --project tsconfig.json scripts/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.12",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.12",
    "@nestjs/platform-express": "^10.4.12",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "oci-common": "^2.102.0",
    "oci-objectstorage": "^2.102.0",
    "oracledb": "^6.7.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
