{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "echo \"Skip install for static landing\"",
  "buildCommand": "mkdir -p public/assets && cp index.html success.html error.html regulamin.html polityka-prywatnosci.html public/ && cp -R assets/. public/assets/",
  "outputDirectory": "public",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/sukces",
      "destination": "/success.html"
    },
    {
      "source": "/blad",
      "destination": "/error.html"
    },
    {
      "source": "/regulamin",
      "destination": "/regulamin.html"
    },
    {
      "source": "/polityka-prywatnosci",
      "destination": "/polityka-prywatnosci.html"
    }
  ]
}
